generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  MENTOR
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  fullName     String
  email        String    @unique
  password     String
  role         UserRole  @default(STUDENT)
  profileImage String?
  bio          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}